---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
---

<section class="py-24 md:py-32" id="#hero">
  <h1
    class="mb-1.5 font-serif text-7xl font-bold tracking-tightest text-white sm:text-8xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-4xl leading-11.5 font-bold tracking-tighter text-primary sm:text-5xl md:text-6xl"
  >
    {specialty}
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <div class="flex flex-col gap-4 sm:flex-row">
    <!-- Get in Touch Button - Opens Gmail directly -->
    <a
      class="inline-block rounded-full bg-primary px-8 py-5 text-sm leading-5 font-medium text-[#fff] hover:bg-primary/90 transition-colors text-center"
      href="https://mail.google.com/mail/?view=cm&fs=1&to=musaa7124@gmail.com"
      target="_blank"
      rel="noopener noreferrer"
    >
      Get in Touch
    </a>
    
    <!-- Download Resume Button -->
    <a
      class="inline-block rounded-full border border-primary px-8 py-5 text-sm leading-5 font-medium text-primary hover:bg-primary hover:text-[#fff] transition-colors text-center"
      href="/Musa_Ali_Unity_Resume.pdf"
      download
    >
      Download Resume
    </a>
  </div>
</section>